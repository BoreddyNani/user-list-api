generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String?
  
  posts Post[]
} 
model User1{
  id Int @id @default(autoincrement())
  email String @unique
  name String?
  password String
  applications JobApplication[]
  isPro Boolean @default(false)
}
model Post { 
  id        Int     @id @default(autoincrement()) 
  title     String
  content   String?
  published Boolean @default(false) 
  author    User    @relation(fields: [authorId], references: [id]) 
  authorId  Int
} 
enum Status {
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model JobApplication{
  id Int @id @default(autoincrement())
  company String
  role String
  status Status
  appliedAt DateTime @default(now())
  notes String?
  resumeUrl String?
  user User1 @relation(fields: [userId], references: [id])
  userId Int
}